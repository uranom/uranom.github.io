<!DOCTYPE html>
<html>
<head>
    <title>Prueba de VS Code</title>
</head>
<body>
    <h1>Hola, VS Code</h1>
    <button id="miBoton">Haz clic aquí</button>

    <script>
        // Este es el código que inspeccionaremos
        const boton = document.getElementById('miBoton');
        
        boton.addEventListener('click', () => {
            let mensaje = "Aprendiendo a depurar";
            console.log(mensaje); // <--- Punto de inspección
            alert("¡Funciona!");
        });
    </script>
</body>
</html>
